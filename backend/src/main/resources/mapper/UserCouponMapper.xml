<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusfoodie.mapper.UserCouponMapper">

    <select id="findByUserId" resultType="com.campusfoodie.model.UserCoupon">
        SELECT * FROM user_coupon WHERE user_id = #{userId} ORDER BY claimed_at DESC
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_coupon (user_id, coupon_id, status, claimed_at)
        VALUES (#{userId}, #{couponId}, #{status}, NOW())
    </insert>

    <update id="update">
        UPDATE user_coupon
        <set>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

</mapper>
