<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusfoodie.mapper.ReviewMapper">

    <select id="findByUser" resultType="com.campusfoodie.model.Review">
        SELECT * FROM review WHERE user = #{user}
    </select>

    <select id="findByRestaurantId" resultType="com.campusfoodie.model.Review">
        SELECT * FROM review WHERE restaurant_id = #{restaurantId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO review (restaurant_id, user, avatar, rating, content, date)
        VALUES (#{restaurantId}, #{user}, #{avatar}, #{rating}, #{content}, #{date})
    </insert>

    <update id="update">
        UPDATE review
        <set>
            <if test="rating != null">rating = #{rating},</if>
            <if test="content != null">content = #{content},</if>
            <if test="date != null">date = #{date},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM review WHERE id = #{id}
    </delete>

</mapper>
