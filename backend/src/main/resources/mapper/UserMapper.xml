<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusfoodie.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.campusfoodie.model.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="role" column="role"/>
        <result property="avatar" column="avatar"/>
        <result property="university" column="university"/>
        <result property="level" column="level"/>
        <result property="exp" column="exp"/>
        <result property="nextLevelExp" column="next_level_exp"/>
        <collection property="favorites" column="id" select="findFavoritesByUserId"/>
    </resultMap>

    <select id="findByUsername" resultMap="UserResultMap">
        SELECT * FROM app_user WHERE username = #{username}
    </select>

    <select id="findById" resultMap="UserResultMap">
        SELECT * FROM app_user WHERE id = #{id}
    </select>

    <select id="findFavoritesByUserId" resultType="com.campusfoodie.model.Restaurant">
        SELECT r.* FROM restaurant r
        JOIN user_favorites uf ON r.id = uf.restaurant_id
        WHERE uf.user_id = #{userId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO app_user (username, password, role, avatar, university, level, exp, next_level_exp)
        VALUES (#{username}, #{password}, #{role}, #{avatar}, #{university}, #{level}, #{exp}, #{nextLevelExp})
    </insert>

    <update id="update">
        UPDATE app_user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="role != null">role = #{role},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="university != null">university = #{university},</if>
            <if test="level != null">level = #{level},</if>
            <if test="exp != null">exp = #{exp},</if>
            <if test="nextLevelExp != null">next_level_exp = #{nextLevelExp},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM app_user WHERE id = #{id}
    </delete>

    <insert id="insertFavorite">
        INSERT IGNORE INTO user_favorites (user_id, restaurant_id) VALUES (#{userId}, #{restaurantId})
    </insert>

    <delete id="deleteFavorite">
        DELETE FROM user_favorites WHERE user_id = #{userId} AND restaurant_id = #{restaurantId}
    </delete>

</mapper>
