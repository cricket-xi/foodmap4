<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campusfoodie.mapper.MenuItemMapper">

    <select id="findByRestaurantId" resultType="com.campusfoodie.model.MenuItem">
        SELECT * FROM menu_item WHERE restaurant_id = #{restaurantId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO menu_item (restaurant_id, name, price, description, image, status)
        VALUES (#{restaurantId}, #{name}, #{price}, #{description}, #{image}, #{status})
    </insert>

    <update id="update">
        UPDATE menu_item
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="price != null">price = #{price},</if>
            <if test="description != null">description = #{description},</if>
            <if test="image != null">image = #{image},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM menu_item WHERE id = #{id}
    </delete>

    <delete id="deleteByRestaurantId">
        DELETE FROM menu_item WHERE restaurant_id = #{restaurantId}
    </delete>

</mapper>
